# Sunucu portu
PORT=3000

# Uygulama ortamı (development | production)
NODE_ENV=development

# CORS için izin verilen origin(ler). Virgülle ayrılmış liste veya tüm origin'ler için *
CORS_ORIGIN=*

# Supabase — service role key SADECE backend'de kullanılır, asla frontend'e sızdırılmaz!
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Google Books API anahtarı (response'larda asla dönmez)
GOOGLE_BOOKS_API_KEY=your-google-books-api-key

# Open Library User-Agent için iletişim bilgisi (API politikası gereği)
OPEN_LIBRARY_CONTACT=ornek@email.com
